+use std::io::{self, Write};
+
+use crate::gfx::Size;
+
+/// Renders the browser framebuffer to the terminal using the kitty graphics
+/// protocol: https://sw.kovidgoyal.net/kitty/graphics-protocol/
+///
+/// The default renderer downsamples every 2x4 pixel block to a single terminal
+/// cell and quantizes it to two colors (see `quad.rs`), which is what makes the
+/// output look blocky. On terminals that implement the kitty graphics protocol
+/// we can instead hand the raw framebuffer to the terminal, which composites it
+/// at full pixel resolution — crisp text and images, straight from Blink.
+///
+/// This requires the page (including text) to be present in the framebuffer,
+/// so graphics mode implies bitmap mode (see `Bridge::BitmapMode`).
+pub struct KittyGraphics {
+    /// Latest framebuffer, packed as RGB (3 bytes per pixel).
+    rgb: Vec<u8>,
+    /// Size of the framebuffer in pixels.
+    pixels: Size,
+    /// Whether the framebuffer changed since the last `encode`.
+    dirty: bool,
+    /// Rotating counter for unique temp-file names.
+    counter: u64,
+    /// Recently written temp files, reaped once the terminal has read them.
+    recent: std::collections::VecDeque<String>,
+    /// Magnifier zoom factor. 1.0 fits the whole page into the cell box (the
+    /// default); larger values show a cropped sub-region scaled up.
+    zoom: f32,
+    /// Center of the zoom viewport as a fraction (0..1) of the framebuffer.
+    /// Panning moves this point; it's kept fractional so it survives resizes.
+    center: (f32, f32),
+}
+
+/// Smallest zoom (whole page) and largest zoom (6x) the magnifier allows.
+const MIN_ZOOM: f32 = 1.0;
+const MAX_ZOOM: f32 = 6.0;
+
+impl KittyGraphics {
+    pub fn new() -> Self {
+        KittyGraphics {
+            rgb: Vec::new(),
+            pixels: Size::new(0, 0),
+            dirty: false,
+            counter: 0,
+            recent: std::collections::VecDeque::new(),
+            zoom: 1.0,
+            center: (0.5, 0.5),
+        }
+    }
+
+    pub fn dirty(&self) -> bool {
+        self.dirty
+    }
+
+    /// Whether the magnifier is currently zoomed in past the fit-to-page level.
+    pub fn is_zoomed(&self) -> bool {
+        self.zoom > MIN_ZOOM + 0.001
+    }
+
+    /// Multiply the zoom by `factor`, keeping the view centered, and request a
+    /// redraw. Clamped to the fit-to-page .. max range.
+    pub fn zoom_by(&mut self, factor: f32) {
+        let zoom = (self.zoom * factor).clamp(MIN_ZOOM, MAX_ZOOM);
+
+        if zoom != self.zoom {
+            self.zoom = zoom;
+            self.clamp_center();
+            self.dirty = true;
+        }
+    }
+
+    /// Pan the viewport by a fraction of the visible crop in each axis (so a
+    /// step feels the same regardless of zoom level). No-op when not zoomed.
+    pub fn pan_by(&mut self, dx: f32, dy: f32) {
+        if !self.is_zoomed() {
+            return;
+        }
+
+        self.center.0 += dx / self.zoom;
+        self.center.1 += dy / self.zoom;
+        self.clamp_center();
+        self.dirty = true;
+    }
+
+    /// Snap back to the whole, centered page.
+    pub fn reset_view(&mut self) {
+        if self.zoom != 1.0 || self.center != (0.5, 0.5) {
+            self.zoom = 1.0;
+            self.center = (0.5, 0.5);
+            self.dirty = true;
+        }
+    }
+
+    /// Keep the viewport center within the range that keeps the crop fully
+    /// inside the framebuffer, so the magnifier never shows out-of-bounds area.
+    fn clamp_center(&mut self) {
+        let half = 0.5 / self.zoom;
+
+        self.center.0 = self.center.0.clamp(half, 1.0 - half);
+        self.center.1 = self.center.1.clamp(half, 1.0 - half);
+    }
+
+    /// The source sub-rectangle (in framebuffer pixels) currently shown, as
+    /// `(x, y, w, h)`. At zoom 1.0 this is the whole framebuffer.
+    fn crop(&self) -> (u32, u32, u32, u32) {
+        let (sw, sh) = (self.pixels.width, self.pixels.height);
+        let crop_w = ((sw as f32 / self.zoom).round() as u32).clamp(1, sw);
+        let crop_h = ((sh as f32 / self.zoom).round() as u32).clamp(1, sh);
+        let x = ((self.center.0 * sw as f32) - crop_w as f32 / 2.0).max(0.0) as u32;
+        let y = ((self.center.1 * sh as f32) - crop_h as f32 / 2.0).max(0.0) as u32;
+
+        (x.min(sw - crop_w), y.min(sh - crop_h), crop_w, crop_h)
+    }
+
+    /// Store a new framebuffer. `pixels` is BGRA8888, as handed to us by
+    /// Chromium in `Renderer::draw_background`.
+    pub fn store(&mut self, pixels: &[u8], size: Size) {
+        let count = (size.width as usize) * (size.height as usize);
+
+        if count == 0 || pixels.len() < count * 4 {
+            return;
+        }
+
+        self.rgb.clear();
+        self.rgb.reserve(count * 3);
+
+        for i in 0..count {
+            // Source is BGRA, kitty's RGB format (f=24) wants R, G, B.
+            self.rgb.push(pixels[i * 4 + 2]);
+            self.rgb.push(pixels[i * 4 + 1]);
+            self.rgb.push(pixels[i * 4 + 0]);
+        }
+
+        self.pixels = size;
+        self.dirty = true;
+    }
+
+    /// Tell the terminal to forget our image and its data. Used on resize so a
+    /// stale placement isn't left scaled to the wrong size. Scoped to image
+    /// id 1 (`d=I,i=1`) so we never touch images other programs may have drawn.
+    pub fn reset() -> &'static [u8] {
+        b"\x1b_Ga=d,d=I,i=1\x1b\\"
+    }
+
+    /// Encode the escape codes that draw the framebuffer into a `cols`x`rows`
+    /// cell box anchored at the 1-based terminal cell (`col`, `row`). The cursor
+    /// is saved and restored so the navigation caret is left untouched.
+    ///
+    /// The framebuffer is handed to the terminal through a temporary file
+    /// (`t=t`) rather than base64'd inline: a single page can be several
+    /// megabytes, and pushing that through the pty every frame is the main
+    /// source of latency. The terminal reads and deletes the file itself.
+    pub fn encode(&mut self, col: u32, row: u32, cols: u32, rows: u32) -> io::Result<Vec<u8>> {
+        let mut out = Vec::new();
+
+        self.dirty = false;
+
+        if self.pixels.width == 0 || self.pixels.height == 0 {
+            return Ok(out);
+        }
+
+        self.counter = self.counter.wrapping_add(1);
+        let dir = std::env::var("TMPDIR").unwrap_or_else(|_| "/tmp".to_string());
+        // The name must contain "tty-graphics-protocol" for kitty to delete the
+        // file itself after reading it.
+        let path = format!(
+            "{}/carbonyl-tty-graphics-protocol-{}-{}.rgb",
+            dir.trim_end_matches('/'),
+            std::process::id(),
+            self.counter
+        );
+
+        std::fs::write(&path, &self.rgb)?;
+
+        // Reap files from earlier frames in case the terminal didn't (e.g. it
+        // isn't kitty, or doesn't honor t=t deletion). By now they've been read.
+        self.recent.push_back(path.clone());
+        while self.recent.len() > 2 {
+            if let Some(old) = self.recent.pop_front() {
+                let _ = std::fs::remove_file(old);
+            }
+        }
+
+        // Save cursor, move to the content origin.
+        write!(out, "\x1b7\x1b[{};{}H", row, col)?;
+
+        // The magnifier shows a sub-rectangle of the framebuffer scaled into the
+        // same cell box: zooming shrinks the crop, panning moves it. At zoom 1.0
+        // the crop is the whole image, so this matches the un-zoomed output.
+        let (crop_x, crop_y, crop_w, crop_h) = self.crop();
+
+        // a=T  transmit and display
+        // f=24 raw RGB
+        // t=t  payload is the path to a temporary file the terminal deletes
+        // s,v  source size in pixels (the full transmitted framebuffer)
+        // x,y,w,h  source sub-rectangle to display (the magnifier crop)
+        // c,r  number of cells to scale the cropped region into
+        // i=1  image id (reused each frame, so the terminal replaces the data)
+        // p=1  placement id (reused, so the terminal replaces the placement)
+        // q=2  suppress the terminal's success/error replies
+        // C=1  do not move the cursor when placing the image
+        write!(
+            out,
+            "\x1b_Ga=T,f=24,t=t,s={},v={},x={},y={},w={},h={},c={},r={},i=1,p=1,q=2,C=1;{}\x1b\\",
+            self.pixels.width,
+            self.pixels.height,
+            crop_x,
+            crop_y,
+            crop_w,
+            crop_h,
+            cols,
+            rows,
+            base64(path.as_bytes())
+        )?;
+
+        // Restore the cursor.
+        write!(out, "\x1b8")?;
+
+        Ok(out)
+    }
+}
+
+/// Standard base64 (RFC 4648) encoder. Kept inline to avoid pulling in a crate.
+fn base64(data: &[u8]) -> String {
+    const ALPHABET: &[u8; 64] =
+        b"ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
+
+    let mut out = String::with_capacity((data.len() + 2) / 3 * 4);
+
+    for chunk in data.chunks(3) {
+        let n = ((chunk[0] as u32) << 16)
+            | ((*chunk.get(1).unwrap_or(&0) as u32) << 8)
+            | (*chunk.get(2).unwrap_or(&0) as u32);
+
+        out.push(ALPHABET[((n >> 18) & 63) as usize] as char);
+        out.push(ALPHABET[((n >> 12) & 63) as usize] as char);
+        out.push(if chunk.len() > 1 {
+            ALPHABET[((n >> 6) & 63) as usize] as char
+        } else {
+            '='
+        });
+        out.push(if chunk.len() > 2 {
+            ALPHABET[(n & 63) as usize] as char
+        } else {
+            '='
+        });
+    }
+
+    out
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    /// Build a graphics backend holding a `w`x`h` framebuffer of dummy pixels.
+    fn with_frame(w: u32, h: u32) -> KittyGraphics {
+        let mut g = KittyGraphics::new();
+        // BGRA8888, contents don't matter for crop geometry.
+        let pixels = vec![0u8; (w * h * 4) as usize];
+        g.store(&pixels, Size::new(w, h));
+        g
+    }
+
+    /// Pull the `key=` integer out of a kitty graphics command string.
+    fn field(cmd: &str, key: &str) -> u32 {
+        let needle = format!(",{key}=");
+        let rest = cmd.split(&needle).nth(1).expect("field present");
+        rest.split(|c: char| !c.is_ascii_digit())
+            .next()
+            .unwrap()
+            .parse()
+            .unwrap()
+    }
+
+    #[test]
+    fn unzoomed_shows_whole_framebuffer() {
+        let mut g = with_frame(800, 600);
+        let cmd = String::from_utf8(g.encode(1, 2, 100, 50).unwrap()).unwrap();
+
+        assert_eq!(field(&cmd, "x"), 0);
+        assert_eq!(field(&cmd, "y"), 0);
+        assert_eq!(field(&cmd, "w"), 800);
+        assert_eq!(field(&cmd, "h"), 600);
+    }
+
+    #[test]
+    fn zoom_in_crops_centered() {
+        let mut g = with_frame(800, 600);
+        g.zoom_by(2.0);
+        let cmd = String::from_utf8(g.encode(1, 2, 100, 50).unwrap()).unwrap();
+
+        // Half-size crop, centered: 400x300 at (200,150).
+        assert_eq!(field(&cmd, "w"), 400);
+        assert_eq!(field(&cmd, "h"), 300);
+        assert_eq!(field(&cmd, "x"), 200);
+        assert_eq!(field(&cmd, "y"), 150);
+    }
+
+    #[test]
+    fn pan_moves_crop_and_clamps_to_edges() {
+        let mut g = with_frame(800, 600);
+        g.zoom_by(2.0);
+
+        // Pan hard left/up many times: the crop must clamp to the top-left.
+        for _ in 0..20 {
+            g.pan_by(-0.15, -0.15);
+        }
+        let cmd = String::from_utf8(g.encode(1, 2, 100, 50).unwrap()).unwrap();
+        assert_eq!(field(&cmd, "x"), 0);
+        assert_eq!(field(&cmd, "y"), 0);
+
+        // Pan hard right/down: clamp to the bottom-right (w-cropw, h-croph).
+        for _ in 0..40 {
+            g.pan_by(0.15, 0.15);
+        }
+        let cmd = String::from_utf8(g.encode(1, 2, 100, 50).unwrap()).unwrap();
+        assert_eq!(field(&cmd, "x"), 400);
+        assert_eq!(field(&cmd, "y"), 300);
+    }
+
+    #[test]
+    fn reset_restores_full_view() {
+        let mut g = with_frame(800, 600);
+        g.zoom_by(3.0);
+        g.pan_by(0.3, 0.3);
+        assert!(g.is_zoomed());
+
+        g.reset_view();
+        assert!(!g.is_zoomed());
+        let cmd = String::from_utf8(g.encode(1, 2, 100, 50).unwrap()).unwrap();
+        assert_eq!(field(&cmd, "w"), 800);
+        assert_eq!(field(&cmd, "h"), 600);
+    }
+
+    #[test]
+    fn zoom_clamps_to_limits() {
+        let mut g = with_frame(800, 600);
+        for _ in 0..50 {
+            g.zoom_by(1.25);
+        }
+        // Never past MAX_ZOOM: crop can't be smaller than width / MAX_ZOOM.
+        let cmd = String::from_utf8(g.encode(1, 2, 100, 50).unwrap()).unwrap();
+        assert_eq!(field(&cmd, "w"), (800.0 / MAX_ZOOM).round() as u32);
+
+        // Zooming out can't go below the whole page.
+        for _ in 0..50 {
+            g.zoom_by(0.8);
+        }
+        assert!(!g.is_zoomed());
+    }
+}
