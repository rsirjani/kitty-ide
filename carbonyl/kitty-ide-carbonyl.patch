new file mode 100644
index 0000000..4960f5a
--- /dev/null
+++ b/src/browser/cdp.rs
@@ -0,0 +1,357 @@
+//! Tiny synchronous Chrome DevTools Protocol client.
+//!
+//! Carbonyl rasterizes page text straight into the framebuffer (bitmap mode),
+//! so the selected text never reaches the terminal side — there's nothing local
+//! to put on the clipboard. Instead we ask the very Chromium we're driving:
+//! the launcher starts it with `--remote-debugging-port` (see `bridge.rs`) and
+//! passes the port down in `CARBONYL_CDP_PORT`. On copy we read
+//! `window.getSelection()` over CDP; on paste we push the text back in with
+//! `Input.insertText`.
+//!
+//! It's a hand-rolled, blocking, dependency-free client: one HTTP GET to find
+//! the page target, a WebSocket upgrade, a single request/response. Everything
+//! is wrapped in short timeouts so a copy/paste never stalls rendering, and any
+//! failure degrades to "do nothing".
+
+use std::io::{Read, Write};
+use std::net::TcpStream;
+use std::time::Duration;
+
+use crate::utils::{base64, log};
+
+/// Env var the launcher uses to hand the chosen debug port to the child.
+pub const PORT_ENV: &str = "CARBONYL_CDP_PORT";
+
+const CONNECT_TIMEOUT: Duration = Duration::from_millis(400);
+const IO_TIMEOUT: Duration = Duration::from_millis(800);
+
+/// The configured debugging port, if the launcher set one.
+fn port() -> Option<u16> {
+    std::env::var(PORT_ENV).ok()?.parse().ok()
+}
+
+/// Whether CDP-backed clipboard is available this run.
+pub fn enabled() -> bool {
+    port().is_some()
+}
+
+/// The current page selection as plain text, or `None` if nothing is selected
+/// (or CDP is unreachable).
+pub fn get_selection() -> Option<String> {
+    let resp = call(
+        "Runtime.evaluate",
+        r#"{"expression":"window.getSelection().toString()","returnByValue":true}"#,
+    )?;
+    let text = extract_string_field(&resp, "value")?;
+
+    if text.is_empty() {
+        None
+    } else {
+        Some(text)
+    }
+}
+
+/// Insert `text` at the focused element, as if typed/pasted. Returns whether the
+/// call was dispatched.
+pub fn insert_text(text: &str) -> bool {
+    let params = format!(r#"{{"text":"{}"}}"#, json_escape(text));
+
+    call("Input.insertText", &params).is_some()
+}
+
+/// Make a single CDP call and return the raw JSON response text.
+fn call(method: &str, params: &str) -> Option<String> {
+    let port = port()?;
+    let path = page_ws_path(port)?;
+    let mut ws = ws_connect(port, &path)?;
+
+    let msg = format!(r#"{{"id":1,"method":"{method}","params":{params}}}"#);
+
+    ws_send_text(&mut ws, msg.as_bytes()).ok()?;
+
+    // Read messages until we see our response (id 1), skipping any events.
+    for _ in 0..32 {
+        let frame = ws_read_message(&mut ws)?;
+        let text = String::from_utf8_lossy(&frame);
+
+        if text.contains("\"id\":1") {
+            return Some(text.into_owned());
+        }
+    }
+
+    None
+}
+
+/// Ask the DevTools HTTP endpoint for a page target's WebSocket path.
+fn page_ws_path(port: u16) -> Option<String> {
+    let mut stream = connect(port)?;
+
+    // The Host header must carry the port: Chromium's DevTools rejects requests
+    // whose Host doesn't match as a DNS-rebinding mitigation.
+    let req = format!("GET /json HTTP/1.1\r\nHost: 127.0.0.1:{port}\r\nConnection: close\r\n\r\n");
+    stream.write_all(req.as_bytes()).ok()?;
+
+    // Read incrementally and stop as soon as the marker appears — DevTools may
+    // hold the connection open (keep-alive), so we can't wait for EOF, and a
+    // read timeout should still let us use whatever arrived.
+    let marker = "/devtools/page/";
+    let mut buf = Vec::new();
+    let mut chunk = [0u8; 4096];
+    loop {
+        match stream.read(&mut chunk) {
+            Ok(0) => break,
+            Ok(n) => {
+                buf.extend_from_slice(&chunk[..n]);
+                if find_sub(&buf, marker.as_bytes()).is_some() {
+                    break;
+                }
+                if buf.len() > 1 << 20 {
+                    break;
+                }
+            }
+            Err(_) => break,
+        }
+    }
+
+    // Grab the first page target's ws URL and keep only the path portion, e.g.
+    // ws://127.0.0.1:PORT/devtools/page/ABC123  ->  /devtools/page/ABC123
+    let body = String::from_utf8_lossy(&buf);
+    let start = body.find(marker)?;
+    let rest = &body[start..];
+    let end = rest.find('"').unwrap_or(rest.len());
+
+    Some(rest[..end].to_string())
+}
+
+/// First index of `needle` in `haystack`.
+fn find_sub(haystack: &[u8], needle: &[u8]) -> Option<usize> {
+    haystack
+        .windows(needle.len())
+        .position(|w| w == needle)
+}
+
+/// Open a WebSocket to a DevTools target and complete the upgrade handshake.
+/// We deliberately send no `Origin` header so Chromium's `--remote-allow-origins`
+/// check doesn't reject us.
+fn ws_connect(port: u16, path: &str) -> Option<TcpStream> {
+    let mut stream = connect(port)?;
+
+    // The key needn't be random for a localhost tool; the server's Accept value
+    // is not verified here.
+    let key = base64::encode(b"carbonyl-clip-01");
+    let req = format!(
+        "GET {path} HTTP/1.1\r\n\
+         Host: 127.0.0.1:{port}\r\n\
+         Upgrade: websocket\r\n\
+         Connection: Upgrade\r\n\
+         Sec-WebSocket-Key: {key}\r\n\
+         Sec-WebSocket-Version: 13\r\n\r\n"
+    );
+
+    stream.write_all(req.as_bytes()).ok()?;
+
+    // Read response headers one byte at a time so we don't swallow frame bytes.
+    let mut headers = Vec::new();
+    let mut byte = [0u8; 1];
+    while !headers.ends_with(b"\r\n\r\n") {
+        if stream.read(&mut byte).ok()? == 0 {
+            return None;
+        }
+        headers.push(byte[0]);
+        if headers.len() > 8192 {
+            return None;
+        }
+    }
+
+    if !headers.starts_with(b"HTTP/1.1 101") {
+        log::debug!("CDP websocket upgrade refused");
+        return None;
+    }
+
+    Some(stream)
+}
+
+/// Send a masked text frame. Per RFC 6455 clients must mask; an all-zero mask
+/// is valid and leaves the payload as-is, which keeps this simple.
+fn ws_send_text(stream: &mut TcpStream, payload: &[u8]) -> std::io::Result<()> {
+    let mut frame = vec![0x81u8]; // FIN + text opcode
+    let len = payload.len();
+
+    if len < 126 {
+        frame.push(0x80 | len as u8);
+    } else if len < 65536 {
+        frame.push(0x80 | 126);
+        frame.extend_from_slice(&(len as u16).to_be_bytes());
+    } else {
+        frame.push(0x80 | 127);
+        frame.extend_from_slice(&(len as u64).to_be_bytes());
+    }
+
+    frame.extend_from_slice(&[0, 0, 0, 0]); // zero mask key
+    frame.extend_from_slice(payload); // payload XOR 0 == payload
+
+    stream.write_all(&frame)
+}
+
+/// Read one full WebSocket message, reassembling continuation frames.
+fn ws_read_message(stream: &mut TcpStream) -> Option<Vec<u8>> {
+    let mut message = Vec::new();
+
+    loop {
+        let mut hdr = [0u8; 2];
+        read_exact(stream, &mut hdr)?;
+
+        let fin = hdr[0] & 0x80 != 0;
+        let opcode = hdr[0] & 0x0f;
+        let masked = hdr[1] & 0x80 != 0;
+        let mut len = (hdr[1] & 0x7f) as usize;
+
+        if len == 126 {
+            let mut ext = [0u8; 2];
+            read_exact(stream, &mut ext)?;
+            len = u16::from_be_bytes(ext) as usize;
+        } else if len == 127 {
+            let mut ext = [0u8; 8];
+            read_exact(stream, &mut ext)?;
+            len = u64::from_be_bytes(ext) as usize;
+        }
+
+        let mut mask = [0u8; 4];
+        if masked {
+            read_exact(stream, &mut mask)?;
+        }
+
+        let mut payload = vec![0u8; len];
+        read_exact(stream, &mut payload)?;
+        if masked {
+            for (i, b) in payload.iter_mut().enumerate() {
+                *b ^= mask[i % 4];
+            }
+        }
+
+        // 0x8 = close. Bail rather than spin.
+        if opcode == 0x8 {
+            return None;
+        }
+
+        message.extend_from_slice(&payload);
+
+        if fin {
+            return Some(message);
+        }
+    }
+}
+
+fn connect(port: u16) -> Option<TcpStream> {
+    let addr = std::net::SocketAddr::from(([127, 0, 0, 1], port));
+    let stream = TcpStream::connect_timeout(&addr, CONNECT_TIMEOUT).ok()?;
+
+    stream.set_read_timeout(Some(IO_TIMEOUT)).ok()?;
+    stream.set_write_timeout(Some(IO_TIMEOUT)).ok()?;
+
+    Some(stream)
+}
+
+fn read_exact(stream: &mut TcpStream, buf: &mut [u8]) -> Option<()> {
+    stream.read_exact(buf).ok()
+}
+
+/// Pull `"<field>":"..."` out of a JSON blob and unescape it. Used for the small,
+/// known CDP responses we care about (the selection string).
+fn extract_string_field(json: &str, field: &str) -> Option<String> {
+    let needle = format!("\"{field}\":\"");
+    let start = json.find(&needle)? + needle.len();
+    let bytes = json.as_bytes();
+    let mut out = String::new();
+    let mut i = start;
+
+    while i < bytes.len() {
+        match bytes[i] {
+            b'"' => return Some(out),
+            b'\\' => {
+                i += 1;
+                match bytes.get(i)? {
+                    b'"' => out.push('"'),
+                    b'\\' => out.push('\\'),
+                    b'/' => out.push('/'),
+                    b'n' => out.push('\n'),
+                    b'r' => out.push('\r'),
+                    b't' => out.push('\t'),
+                    b'b' => out.push('\u{08}'),
+                    b'f' => out.push('\u{0c}'),
+                    b'u' => {
+                        let hex = json.get(i + 1..i + 5)?;
+                        let code = u32::from_str_radix(hex, 16).ok()?;
+                        out.push(char::from_u32(code).unwrap_or('\u{fffd}'));
+                        i += 4;
+                    }
+                    other => out.push(*other as char),
+                }
+            }
+            _ => {
+                // Copy a full UTF-8 sequence so multibyte chars survive.
+                let ch_len = utf8_len(bytes[i]);
+                let end = (i + ch_len).min(bytes.len());
+                out.push_str(&json[i..end]);
+                i = end;
+                continue;
+            }
+        }
+        i += 1;
+    }
+
+    None
+}
+
+fn utf8_len(first: u8) -> usize {
+    match first {
+        0x00..=0x7f => 1,
+        0xc0..=0xdf => 2,
+        0xe0..=0xef => 3,
+        _ => 4,
+    }
+}
+
+/// Escape a string for embedding in a JSON string literal.
+fn json_escape(text: &str) -> String {
+    let mut out = String::with_capacity(text.len() + 8);
+
+    for ch in text.chars() {
+        match ch {
+            '"' => out.push_str("\\\""),
+            '\\' => out.push_str("\\\\"),
+            '\n' => out.push_str("\\n"),
+            '\r' => out.push_str("\\r"),
+            '\t' => out.push_str("\\t"),
+            c if (c as u32) < 0x20 => out.push_str(&format!("\\u{:04x}", c as u32)),
+            c => out.push(c),
+        }
+    }
+
+    out
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn extracts_and_unescapes() {
+        let json = r#"{"id":1,"result":{"result":{"type":"string","value":"line1\ntab\there \"q\" é"}}}"#;
+        assert_eq!(
+            extract_string_field(json, "value").unwrap(),
+            "line1\ntab\there \"q\" é"
+        );
+    }
+
+    #[test]
+    fn empty_value() {
+        let json = r#"{"id":1,"result":{"result":{"type":"string","value":""}}}"#;
+        assert_eq!(extract_string_field(json, "value").unwrap(), "");
+    }
+
+    #[test]
+    fn json_escape_roundtrip_chars() {
+        assert_eq!(json_escape("a\"b\\c\nd"), "a\\\"b\\\\c\\nd");
+    }
+}
