+++ b/src/input/osc.rs
@@ -0,0 +1,70 @@
+use std::ops::ControlFlow;
+
+use crate::utils::base64;
+
+use super::{Event, ParseControlFlow};
+
+/// Collects an OSC (Operating System Command) string — `ESC ] ... terminator`,
+/// where the terminator is BEL (`0x07`) or ST (`ESC \`). We only care about
+/// OSC 52, the terminal clipboard reply: `52;<targets>;<base64>`. Everything
+/// else is parsed and dropped so it doesn't leak into the page as keystrokes.
+#[derive(Default)]
+pub struct Osc {
+    buf: Vec<u8>,
+    saw_esc: bool,
+}
+
+impl Osc {
+    pub fn new() -> Self {
+        Self::default()
+    }
+
+    pub fn parse(&mut self, key: u8) -> ParseControlFlow {
+        // A pending ESC means we're looking for the `\` of an ST terminator.
+        if self.saw_esc {
+            self.saw_esc = false;
+            // Either way the sequence ends here; `\` is ST, anything else is
+            // malformed and we still stop rather than swallow the stream.
+            return ControlFlow::Break(self.finish());
+        }
+
+        match key {
+            // BEL terminates the OSC.
+            0x07 => ControlFlow::Break(self.finish()),
+            // ESC may begin an ST terminator; wait for the next byte.
+            0x1b => {
+                self.saw_esc = true;
+                ControlFlow::Continue(None)
+            }
+            _ => {
+                // Guard against an unterminated/oversized OSC eating memory.
+                if self.buf.len() < 1 << 20 {
+                    self.buf.push(key);
+                }
+                ControlFlow::Continue(None)
+            }
+        }
+    }
+
+    /// Decode the collected payload into a paste event, if it's an OSC 52
+    /// clipboard reply with valid base64.
+    fn finish(&mut self) -> Option<Event> {
+        let buf = std::mem::take(&mut self.buf);
+        let payload = std::str::from_utf8(&buf).ok()?;
+
+        // `52;<targets>;<base64>` — drop the `52;` and the targets field.
+        let rest = payload.strip_prefix("52;")?;
+        let b64 = rest.splitn(2, ';').nth(1)?;
+
+        // A read query echoes back as `52;c;?`; ignore that, only accept data.
+        if b64 == "?" {
+            return None;
+        }
+
+        let bytes = base64::decode(b64.as_bytes())?;
+
+        Some(Event::Paste {
+            text: String::from_utf8_lossy(&bytes).into_owned(),
+        })
+    }
+}
