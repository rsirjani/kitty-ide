+//! Standard base64 (RFC 4648) encode/decode, kept inline to avoid a crate.
+//! Used for the OSC 52 clipboard protocol and CDP payloads.
+
+const ALPHABET: &[u8; 64] =
+    b"ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
+
+/// Encode bytes as standard base64 with `=` padding.
+pub fn encode(data: &[u8]) -> String {
+    let mut out = String::with_capacity((data.len() + 2) / 3 * 4);
+
+    for chunk in data.chunks(3) {
+        let n = ((chunk[0] as u32) << 16)
+            | ((*chunk.get(1).unwrap_or(&0) as u32) << 8)
+            | (*chunk.get(2).unwrap_or(&0) as u32);
+
+        out.push(ALPHABET[((n >> 18) & 63) as usize] as char);
+        out.push(ALPHABET[((n >> 12) & 63) as usize] as char);
+        out.push(if chunk.len() > 1 {
+            ALPHABET[((n >> 6) & 63) as usize] as char
+        } else {
+            '='
+        });
+        out.push(if chunk.len() > 2 {
+            ALPHABET[(n & 63) as usize] as char
+        } else {
+            '='
+        });
+    }
+
+    out
+}
+
+/// Decode standard base64, ignoring whitespace and padding. Returns `None` on
+/// any invalid (non-alphabet, non-padding, non-whitespace) byte.
+pub fn decode(data: &[u8]) -> Option<Vec<u8>> {
+    let mut out = Vec::with_capacity(data.len() / 4 * 3);
+    let mut acc: u32 = 0;
+    let mut bits = 0u32;
+
+    for &b in data {
+        let val = match b {
+            b'A'..=b'Z' => b - b'A',
+            b'a'..=b'z' => b - b'a' + 26,
+            b'0'..=b'9' => b - b'0' + 52,
+            b'+' => 62,
+            b'/' => 63,
+            b'=' => break,
+            b' ' | b'\t' | b'\r' | b'\n' => continue,
+            _ => return None,
+        } as u32;
+
+        acc = (acc << 6) | val;
+        bits += 6;
+
+        if bits >= 8 {
+            bits -= 8;
+            out.push((acc >> bits) as u8);
+        }
+    }
+
+    Some(out)
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn round_trips() {
+        for s in ["", "f", "fo", "foo", "foob", "fooba", "foobar", "héllo 🌍"] {
+            let enc = encode(s.as_bytes());
+            assert_eq!(decode(enc.as_bytes()).unwrap(), s.as_bytes());
+        }
+    }
+
+    #[test]
+    fn known_vectors() {
+        assert_eq!(encode(b"foobar"), "Zm9vYmFy");
+        assert_eq!(decode(b"Zm9vYmFy").unwrap(), b"foobar");
+    }
+
+    #[test]
+    fn ignores_whitespace_and_rejects_garbage() {
+        assert_eq!(decode(b"Zm9v\nYmFy").unwrap(), b"foobar");
+        assert!(decode(b"not valid!").is_none());
+    }
+}
