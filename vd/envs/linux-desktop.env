# The default Virtual Desktop: a headless X11 Linux desktop in Docker.
# Bring it up with:  ide-vd up linux-desktop
provider=docker
image=ide-vd-linux
geometry=1280x800
vncport=5901
# GPU acceleration via the NVIDIA container toolkit + VirtualGL (gpu=nvidia|none).
# Run GPU apps through VirtualGL:  ide-vd gl <app>   or   ide-vd launch --gpu <app>
gpu=nvidia
# Host directory bind-mounted at /work inside the desktop (so apps can reach
# your code). Change to taste.
mount=$HOME/projects
