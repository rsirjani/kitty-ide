#!/usr/bin/env bash
# Virtual Desktop provider: a full-OS VM via QEMU's built-in VNC server.
# Ready to use for Windows / macOS / other-Linux VMs — point an env at a disk
# image (and optionally an install ISO) and `ide-vd up` it. Nothing is
# provisioned until you supply an image; QEMU itself must be installed.
#
# Contract:  up|down|status|endpoint|run <envfile>
# Reads from the env file:  disk, iso, memory (MB), cpus, vncport, accel
set -euo pipefail

action="${1:?}"; envfile="${2:?}"; shift 2 || true
# shellcheck disable=SC1090
provider=qemu disk= iso= memory=4096 cpus=2 vncport=5902 accel=kvm
source "$envfile"

# Per-window isolation: suffix the VM name + pidfile with IDE_VD_INSTANCE (the
# kitty pid), like the docker provider, so two IDE windows don't drive the same
# VM. The VNC port is allocated dynamically (free_port) instead of a fixed one,
# and remembered in a portfile so endpoint/status report the right port.
inst="${IDE_VD_INSTANCE:-}"
name="ide-vd-$(basename "$envfile" .env)${inst:+-$inst}"
pidfile="$HOME/.cache/ide-vd/$name.pid"
portfile="$pidfile.port"

alive() { [ -f "$pidfile" ] && kill -0 "$(cat "$pidfile")" 2>/dev/null; }
cur_port() { cat "$portfile" 2>/dev/null || echo "$vncport"; }
free_port() {            # first free TCP port at/after $1 (per-window VMs differ)
  local p="$1" i
  for i in $(seq 0 64); do
    if ! (exec 3<>"/dev/tcp/127.0.0.1/$p") 2>/dev/null; then echo "$p"; return 0; fi
    exec 3>&- 3<&- 2>/dev/null; p=$((p + 1))
  done
  echo "$1"
}

case "$action" in
  up)
    alive && exit 0
    command -v qemu-system-x86_64 >/dev/null || { echo "qemu: install qemu-system-x86_64" >&2; exit 1; }
    [ -n "$disk" ] && [ -f "$disk" ] || { echo "qemu: env 'disk=' must point at a VM image" >&2; exit 1; }
    mkdir -p "$(dirname "$pidfile")"
    port="$(free_port "$vncport")"; echo "$port" > "$portfile"
    display=$(( port - 5900 ))
    args=(qemu-system-x86_64 -name "$name" -m "$memory" -smp "$cpus"
          -drive file="$disk",if=virtio
          -vnc "127.0.0.1:${display}" -usbdevice tablet)   # tablet => absolute mouse
    [ "$accel" = kvm ] && [ -e /dev/kvm ] && args+=(-enable-kvm -cpu host)
    [ -n "$iso" ] && args+=(-cdrom "$iso" -boot d)
    "${args[@]}" >/dev/null 2>&1 &
    echo $! > "$pidfile"
    for _ in $(seq 1 150); do
      if (exec 3<>"/dev/tcp/127.0.0.1/${port}") 2>/dev/null; then exec 3>&- 3<&-; exit 0; fi
      sleep 0.2
    done
    echo "qemu: VNC port ${port} never came up" >&2; exit 1
    ;;

  down)
    alive && kill "$(cat "$pidfile")" 2>/dev/null || true
    rm -f "$pidfile" "$portfile"
    ;;

  status)
    if alive; then echo up; else echo down; fi
    ;;

  endpoint)
    alive && printf '127.0.0.1\t%s\t\n' "$(cur_port)"
    ;;

  run)
    echo "qemu: 'run' unsupported — launch apps inside the guest OS" >&2; exit 1
    ;;

  *) echo "qemu provider: unknown action '$action'" >&2; exit 2 ;;
esac
