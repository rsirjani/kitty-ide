#!/usr/bin/env bash
# Rendered Markdown view for the IDE editor pane.
#
# glow's own pager (`glow -p`) exits immediately when kitty launches it inside an
# overlay (the TUI bails before it can take over the screen), so the tab would
# vanish. Instead we render with glow and page the result through `less` ourselves
# -- which reliably stays open. Press q to close the tab; Alt+M (or the tab-bar ⇄)
# morphs to nvim for editing.
export PATH="$HOME/.local/bin:$PATH"
file="$1"
[ -n "$file" ] || exit 0
cols=$(tput cols 2>/dev/null || echo 100)

# Cache glow's rendered output keyed by abspath+mtime+width, so re-opening the
# same (unchanged) markdown is instant instead of re-rendering each time. The
# cache lives under this instance's /tmp render dir, which `ide` cleans on exit.
. ide-sock 2>/dev/null || true
cache_dir="/tmp/ide-${IDE_ID:-default}-render"; mkdir -p "$cache_dir" 2>/dev/null || true
key="$(printf '%s|%s|%s' "$(readlink -f -- "$file" 2>/dev/null || echo "$file")" \
        "$(stat -c %Y -- "$file" 2>/dev/null || echo 0)" "$cols" | md5sum | cut -d' ' -f1)"
cache="$cache_dir/md-$key.ansi"

# -s dark: match the IDE's dark theme · -w: wrap to the pane width · less -R: keep
# glow's ANSI colours. LESS=-R also avoids a stray "missing filename" if glow fails.
if [ ! -s "$cache" ]; then
  glow -s dark -w "$cols" -- "$file" 2>/dev/null > "$cache" || true
fi
if [ -s "$cache" ]; then less -R -- "$cache"
else glow -s dark -w "$cols" -- "$file" 2>/dev/null | less -R; fi
