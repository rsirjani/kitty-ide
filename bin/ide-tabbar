#!/usr/bin/env python3
# Interactive tab bar for the kitty IDE. Lists document overlays (var doc=1),
# highlights the focused one, switches to a tab on click, and closes one via its
# "×". Runs in the thin "tabbar" pane on top of the editor column, and keeps
# itself pinned to a single row so it stays fixed-height as the editor resizes.
import sys, os, json, subprocess, select, re, signal

ACTIVE_FG, ACTIVE_BG = "#1e1e2e", "#89b4fa"   # blue chip for the active doc
IDLE_FG, SEP_FG      = "#a6adc8", "#585b70"
BTN_FG, BTN_BG       = "#1e1e2e", "#a6e3a1"   # green chip for the "+ web" button
CLOSE_FG             = "#f38ba8"              # red "×" close glyph
MORPH_FG             = "#f9e2af"              # yellow "⇄" rendered<->editable toggle

NEW_BROWSER = "__newbrowser__"

# File types that can morph between a rendered view and an editable form. Media
# with no editable counterpart (video/audio/pdf) and plain text/code are omitted.
MORPH_EXTS = {
    "md","markdown","mdown","mkd","mkdn","html","htm","xhtml",
    "png","jpg","jpeg","gif","webp","bmp","tiff","tif","ico","svg","avif",
    "csv","tsv","xlsx","xls","ods","xlsm","docx","doc","odt","rtf","pptx","ppt","odp",
}

def morphable(file, vmode):
    if not file or vmode not in ("view", "edit"):
        return False
    ext = file.rsplit(".", 1)[-1].lower() if "." in file else ""
    return ext in MORPH_EXTS

# Per-instance active-doc file, keyed off THIS IDE's control socket
# (KITTY_LISTEN_ON = unix:/tmp/ide.sock-<pid>), so sibling IDEs never share it.
def _active_doc_path():
    s = os.environ.get("KITTY_LISTEN_ON", "")
    iid = s.rsplit("ide.sock-", 1)[-1] if "ide.sock-" in s else "default"
    return f"/tmp/ide-{iid}-active-doc"

ACTIVE_DOC = _active_doc_path()

def fg(h): r,g,b=(int(h[i:i+2],16) for i in (1,3,5)); return f"\033[38;2;{r};{g};{b}m"
def bg(h): r,g,b=(int(h[i:i+2],16) for i in (1,3,5)); return f"\033[48;2;{r};{g};{b}m"
RST = "\033[0m"

def kitty(*args):
    try:
        return subprocess.run(["kitty","@",*args], capture_output=True, text=True, timeout=2)
    except Exception:
        return None

def snapshot():
    """One `kitty @ ls` -> (docs list, this tabbar's (rows, cols))."""
    r = kitty("ls"); docs = []; tb_dims = (None, None)
    if not r or not r.stdout: return docs, tb_dims
    try: data = json.loads(r.stdout)
    except Exception: return docs, tb_dims
    for w in data:
        for t in w.get("tabs", []):
            for win in t.get("windows", []):
                v = win.get("user_vars", {})
                if v.get("doc") == "1":
                    docs.append((win["id"], v.get("title", "?"), bool(win.get("is_focused")),
                                 v.get("vmode", ""), v.get("file", "")))
                if v.get("pane") == "tabbar":
                    tb_dims = (win.get("lines"), win.get("columns"))
    return docs, tb_dims

def pin_one_row(tb_lines):
    """Keep the tab bar exactly one row tall; give the freed space to the editor."""
    if tb_lines and tb_lines > 1:
        kitty("resize-window", "--axis", "vertical",
              "--increment", str(1 - tb_lines), "--match", "var:pane=tabbar")

def render(ds, cols=None):
    """Draw the tab bar within `cols` columns. Long/many tabs no longer push the
    '+ web' button off-screen or mis-map click columns: titles are truncated, the
    visible tabs scroll to keep the focused one in view (‹/› markers), and the
    '+ web' button is always pinned at the right and clickable."""
    sys.stdout.write("\033[H\033[2J")
    cols = cols or 80
    web = " + web "
    budget = max(1, cols - len(web))        # reserve the pinned web button

    def title_disp(t):
        t = t if t is not None else "?"
        return (t[:18] + "…") if len(t) > 19 else t

    # Plan each tab's segments (with truncated title) and its total width.
    tabs = []
    for wid, title, foc, vmode, file in ds:
        segs = [(f" {title_disp(title)} ", "focus", wid), ("× ", "close", wid)]
        if foc and morphable(file, vmode):
            segs.append((f"⇄ {'view' if vmode == 'edit' else 'edit'} ", "morph", wid))
        segs.append(("│", "sep", None))
        tabs.append({"segs": segs, "w": sum(len(s[0]) for s in segs), "foc": foc})

    ranges, col = [], 1
    if not tabs:
        msg = "  open a file from the explorer  "[:budget]
        sys.stdout.write(fg(IDLE_FG) + msg + RST); col += len(msg)
    else:
        lo, hi = 0, len(tabs)
        if sum(t["w"] for t in tabs) > budget:   # scroll a window around focus
            fi = next((i for i, t in enumerate(tabs) if t["foc"]), len(tabs) - 1)
            avail, used, lo, hi = budget - 2, tabs[fi]["w"], fi, fi + 1
            while True:
                grew = False
                if hi < len(tabs) and used + tabs[hi]["w"] <= avail:
                    used += tabs[hi]["w"]; hi += 1; grew = True
                if lo > 0 and used + tabs[lo - 1]["w"] <= avail:
                    lo -= 1; used += tabs[lo]["w"]; grew = True
                if not grew:
                    break
        if lo > 0:
            sys.stdout.write(fg(SEP_FG) + "‹" + RST); col += 1
        for t in tabs[lo:hi]:
            for text, kind, wid in t["segs"]:
                start = col
                if kind == "focus":
                    sys.stdout.write((bg(ACTIVE_BG) + fg(ACTIVE_FG) if t["foc"] else fg(IDLE_FG)) + text + RST)
                elif kind == "close":
                    sys.stdout.write((bg(ACTIVE_BG) if t["foc"] else "") + fg(CLOSE_FG) + text + RST)
                elif kind == "morph":
                    sys.stdout.write(bg(ACTIVE_BG) + fg(MORPH_FG) + text + RST)
                else:
                    sys.stdout.write(fg(SEP_FG) + text + RST)
                col += len(text)
                if kind in ("focus", "close", "morph"):
                    ranges.append((start, col, kind, wid))
        if hi < len(tabs):
            sys.stdout.write(fg(SEP_FG) + "›" + RST); col += 1
    # "+ web" button — always pinned at the right and clickable.
    start = col
    sys.stdout.write(bg(BTN_BG) + fg(BTN_FG) + web + RST)
    col += len(web)
    ranges.append((start, col, "newbrowser", None))
    sys.stdout.flush()
    return ranges

def focus(wid):
    kitty("focus-window", "--match", f"id:{wid}")
    try: open(ACTIVE_DOC, "w").write(str(wid))   # for ide-pane "editor"
    except Exception: pass

def _window_fg_pids(wid):
    """Foreground process pids of window `wid` (the carbonyl/nvim/etc running in
    it), so we can reap them on close — a carbonyl tab is a full Chromium whose
    detached children otherwise linger and keep holding their profile lock."""
    r = kitty("ls")
    if not r or not r.stdout:
        return []
    try:
        data = json.loads(r.stdout)
    except Exception:
        return []
    for w in data:
        for t in w.get("tabs", []):
            for win in t.get("windows", []):
                if win.get("id") == wid:
                    return [p["pid"] for p in win.get("foreground_processes", []) if p.get("pid")]
    return []

def close(wid):
    pids = _window_fg_pids(wid)
    kitty("close-window", "--match", f"id:{wid}")
    # SIGTERM the foreground process group(s): closing the kitty window alone can
    # leave carbonyl's Chromium children orphaned (issue: web tabs not really
    # closable + Chromium/profile leak).
    for pid in pids:
        try:
            os.killpg(os.getpgid(pid), signal.SIGTERM)
        except (ProcessLookupError, PermissionError, OSError):
            pass
    try:
        if open(ACTIVE_DOC).read().strip() == str(wid):
            os.remove(ACTIVE_DOC)
    except Exception: pass

def main():
    # cbreak mode: read mouse bytes immediately (not line-buffered) and hide the cursor
    import termios, tty
    fd = sys.stdin.fileno()
    old_attr = termios.tcgetattr(fd)
    tty.setcbreak(fd)
    sys.stdout.write("\033]2;tabbar\033\\")     # window title
    sys.stdout.write("\033[?25l")                 # hide cursor
    sys.stdout.write("\033[?1000;1006h")          # SGR mouse reporting
    sys.stdout.flush()
    last, last_dims, ranges, buf = None, None, [], ""
    while True:
        r, _, _ = select.select([sys.stdin], [], [], 0.1)
        cur, tb_dims = snapshot()
        if tb_dims != last_dims:                  # the bar was resized
            pin_one_row(tb_dims[0])               # snap it back to one row
            last_dims = tb_dims
            last = None                           # force a redraw (don't go blank)
        if cur != last:
            ranges = render(cur, tb_dims[1]); last = cur
        if r:
            try: data = os.read(sys.stdin.fileno(), 4096).decode("utf-8", "replace")
            except OSError: data = ""
            buf += data
            for mt in re.finditer(r"\033\[<(\d+);(\d+);(\d+)([Mm])", buf):
                b, x, _, typ = int(mt.group(1)), int(mt.group(2)), mt.group(3), mt.group(4)
                if typ == "M" and b == 0:          # left button press
                    for s, e, kind, wid in ranges:
                        if s <= x < e:
                            if kind == "newbrowser":
                                subprocess.Popen(["ide-open", "browser"])
                            elif kind == "morph":
                                subprocess.Popen(["ide-open", "toggle"])
                            elif kind == "close":
                                close(wid)
                            else:
                                focus(wid)
                            last = None; break
            buf = ""

if __name__ == "__main__":
    try: main()
    except KeyboardInterrupt: pass
