#!/usr/bin/env python3
# Idle animation for the IDE editor pane, shown when no document is open.
# A sleeping cat with rising z's. Centered, resize-aware, flicker-free.
import sys, time, shutil

ESC = "\033"
def fg(h): return f"{ESC}[38;2;{int(h[1:3],16)};{int(h[3:5],16)};{int(h[5:7],16)}m"
RST = f"{ESC}[0m"
CAT_COL, Z_COL, HINT_COL = fg("#b4befe"), fg("#cba6f7"), fg("#6c7086")

CAT = r'''
       |\      _,,,---,,_
      /,`.-'`'    -.  ;-;;,_
     |,4-  ) )-,_. ,\ (  `'-'
    '---''(_/--'  `-'\_)
'''.strip("\n").split("\n")

HINT = "open a file from the explorer    ·    tex/md → editor    ·    pdf → reader"
LIFE = 5  # how many cells a z rises before it loops

def main():
    sys.stdout.write(f"{ESC}]2;content{ESC}\\{ESC}[?25l")  # title + hide cursor
    sys.stdout.flush()
    last_size = None
    frame = 0
    try:
        while True:
            size = shutil.get_terminal_size((80, 24))
            cols, rows = size.columns, size.lines
            cat_w = max(len(l) for l in CAT)
            cat_h = len(CAT)
            cx = max(0, (cols - cat_w) // 2)
            cy = max(LIFE + 1, (rows - cat_h) // 2)
            hx = cx + 8  # z's drift up-right from the cat's head
            buf = []
            if last_size != (cols, rows):
                buf.append(f"{ESC}[2J")          # full clear only on first frame / resize
                last_size = (cols, rows)
            # blank the diagonal z-region so rising z's leave no trail
            for r in range(max(1, cy - LIFE), cy):
                buf.append(f"{ESC}[{r};{hx}H" + " " * (LIFE + 2))
            # rising z particles
            for i in range(3):
                p = (frame // 2 + i * 2) % LIFE
                zy, zx = cy - 1 - p, hx + p
                if zy >= 1:
                    ch = "z" if p < 3 else "Z"
                    buf.append(f"{ESC}[{zy};{zx}H{Z_COL}{ch}{RST}")
            # the cat (static -> redraws over itself, no flicker)
            for i, line in enumerate(CAT):
                buf.append(f"{ESC}[{cy+i};{cx}H{CAT_COL}{line}{RST}")
            # dim hint below
            hint_x = max(0, (cols - len(HINT)) // 2)
            buf.append(f"{ESC}[{cy+cat_h+2};{hint_x}H{HINT_COL}{HINT}{RST}")
            sys.stdout.write("".join(buf))
            sys.stdout.flush()
            frame += 1
            time.sleep(0.16)
    except (KeyboardInterrupt, BrokenPipeError):
        pass
    finally:
        sys.stdout.write(f"{ESC}[?25h")
        sys.stdout.flush()

if __name__ == "__main__":
    main()
