#!/usr/bin/env python3
# Idle animation for the IDE editor pane, shown when no document is open.
# A sleeping cat (Braille art) with rising z's. Centered, resize-aware.
import sys, time, shutil, os, select
try:
    import termios
except ImportError:
    termios = None

ESC = "\033"
def fg(h): return f"{ESC}[38;2;{int(h[1:3],16)};{int(h[3:5],16)};{int(h[5:7],16)}m"
RST = f"{ESC}[0m"
CAT_COL, Z_COL, HINT_COL = fg("#cdd6f4"), fg("#cba6f7"), fg("#6c7086")

# Sleeping cat, drawn in Unicode Braille. Kept verbatim; the blank cells are
# Braille-space (U+2800), so redrawing the whole grid each frame paints over
# (and clears) the previous frame's z's wherever they sat.
CAT = '''
⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢠⣀⣀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠈⠉⣉⣙⣷⡦⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢤⣴⠖⠛⠉⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⣀⣀⣉⠛⠓⠶⢤⣄⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⣤⣽⡿⠟⠁⠀⠀⠀⠉⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠈⠉⠙⠛⠷⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⣀⣀⣤⣤⣤⣤⣀⣀⡀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠀⠀⠀⠀⠀⠀⠀⠀⣀⣀⣤⡶⠶⠛⠉⠉⠉⠉⠁⠀⠀⠀⠀⠉⠙⠿⠓⠒⠶⢺⡇⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⢶⡶⠶⠶⠶⠖⠖⠛⠉⠉⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⣴⡟⠁⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠘⣧⡀⠀⠀⣀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢀⣼⠏⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠀⠈⠻⢤⣼⡏⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠈⣏⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠀⠀⠀⠀⢻⡀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⠀⢀⣀⡀⢀⣿⡿⠶⠶⣤⡀⠀⠀⠀⠀⠀⠀⠀⠀⠀
⠀⠀⠀⠀⢸⡇⠀⣀⣀⠀⢀⣀⣤⡀⠀⠀⠀⠀⠸⠶⠶⠚⠛⠋⢹⣿⣿⣟⣉⠉⠒⠀⠻⣦⣠⣤⣤⣤⣄⣀⠀⠀
⠀⢀⣤⢾⣿⣷⣶⡍⠙⠙⠛⠋⠉⠀⠀⢴⡶⠀⠀⠀⠀⢀⣠⡶⠟⠛⠛⣷⠀⠉⠁⠀⠀⠈⣧⡀⠀⠩⣀⠈⢹⣆
⠀⣠⠔⢉⡴⢿⣿⡟⠛⠛⠛⠶⣤⣀⠀⠀⠀⠀⠀⠀⣴⡿⠋⠀⠀⠀⢀⡉⠀⠀⠀⠀⢀⣼⠛⠛⢛⣿⡿⠀⣾⡟
⠀⠁⣰⠋⢀⡿⠁⠀⠀⠀⠀⠀⠀⠉⠻⣦⡀⠀⠀⣼⠟⠀⠀⠀⢀⣠⣾⢁⣀⣤⣴⡶⠟⣁⣴⠞⠋⠉⢀⣼⣿⠁
⠀⠀⠉⠀⠈⠷⣄⡀⠀⠀⠀⠀⠀⠀⠀⠈⢿⡗⠚⡏⠀⢀⣤⡶⠛⠋⠉⠉⠉⠉⠀⣠⣾⠟⢁⣀⣤⣶⣿⠟⠁⠀
⠀⠀⠀⠀⠀⠀⠀⠈⠉⠑⠲⠤⣄⣦⣤⡴⠞⠁⠀⠉⠙⠉⠁⠀⠀⠀⠀⠀⠀⠀⠀⠹⠿⠾⠾⠟⠛⠁⠀⠀⠀⠀
'''.strip("\n").split("\n")

HINT = "open a file from the explorer    ·    tex/md → editor    ·    pdf → reader"

# The art's top rows are the cat's own sleepy z's. Split them off and animate
# just those -- lifting them up off the cat and looping -- while the cat below
# stays put. (rows 0..ZSPLIT-1 = the z's, the rest = the cat.)
ZSPLIT = 6
MAXRISE = 4                 # how far (rows) the z's drift up before looping
ZBASE = (203, 166, 247)     # z colour (#cba6f7), faded toward the bg as they rise
BG = (30, 30, 46)
Z_ART = CAT[:ZSPLIT]
CAT_ART = CAT[ZSPLIT:]
def zfade(off):
    t = (off / MAXRISE) * 0.72
    c = tuple(int(ZBASE[k] * (1 - t) + BG[k] * t) for k in range(3))
    return f"{ESC}[38;2;{c[0]};{c[1]};{c[2]}m"

def main():
    # The idle screen is not an input surface: put the tty in no-echo,
    # non-canonical mode so keystrokes typed here aren't echoed onto the
    # animation, and drain them each frame so nothing leaks through.
    fd = sys.stdin.fileno()
    old_attr = None
    if termios is not None and sys.stdin.isatty():
        try:
            old_attr = termios.tcgetattr(fd)
            new_attr = termios.tcgetattr(fd)
            new_attr[3] &= ~(termios.ECHO | termios.ICANON)   # lflags
            termios.tcsetattr(fd, termios.TCSANOW, new_attr)
        except Exception:
            old_attr = None

    sys.stdout.write(f"{ESC}]2;content{ESC}\\{ESC}[?25l")  # title + hide cursor
    sys.stdout.flush()
    last_size = None
    frame = 0
    try:
        while True:
            while select.select([sys.stdin], [], [], 0)[0]:   # discard idle-pane keystrokes
                try:
                    if not os.read(fd, 4096):
                        break
                except OSError:
                    break
            size = shutil.get_terminal_size((80, 24))
            cols, rows = size.columns, size.lines
            cat_w = max(len(l) for l in CAT)
            cat_h = len(CAT)
            cx = max(0, (cols - cat_w) // 2)
            cy = max(MAXRISE + 1, (rows - cat_h) // 2)
            off = (frame // 3) % (MAXRISE + 1)   # z lift, 0..MAXRISE, looping
            buf = []
            if last_size != (cols, rows):
                buf.append(f"{ESC}[2J")          # full clear only on first frame / resize
                last_size = (cols, rows)
            # clear the z fly-zone above the cat so risen z's leave no trail
            for r in range(max(1, cy - MAXRISE), cy + ZSPLIT):
                buf.append(f"{ESC}[{r};{cx}H" + " " * cat_w)
            # the cat body (static), sitting below the z's
            for i, line in enumerate(CAT_ART):
                buf.append(f"{ESC}[{cy+ZSPLIT+i};{cx}H{CAT_COL}{line}{RST}")
            # the cat's z's, lifted up by `off` and fading as they rise
            zcol = zfade(off)
            for i, line in enumerate(Z_ART):
                rr = cy + i - off
                if rr >= 1:
                    buf.append(f"{ESC}[{rr};{cx}H{zcol}{line}{RST}")
            # dim hint below
            hint_x = max(0, (cols - len(HINT)) // 2)
            buf.append(f"{ESC}[{cy+cat_h+2};{hint_x}H{HINT_COL}{HINT}{RST}")
            sys.stdout.write("".join(buf))
            sys.stdout.flush()
            frame += 1
            time.sleep(0.16)
    except (KeyboardInterrupt, BrokenPipeError):
        pass
    finally:
        if old_attr is not None:
            try: termios.tcsetattr(fd, termios.TCSANOW, old_attr)
            except Exception: pass
        sys.stdout.write(f"{ESC}[?25h")
        sys.stdout.flush()

if __name__ == "__main__":
    main()
