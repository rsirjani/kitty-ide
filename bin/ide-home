в Җв Җв Җв Җв Җв Җв Җв Ҳв үв ‘в Ів ӨвЈ„вЈҰвЈӨвЎҙв һв Ғв Җв үв ҷв үв Ғв Җв Җв Җв Җв Җв Җв Җв Җв №в ҝв ҫв ҫв ҹв ӣв Ғв Җв Җв Җв Җ
'''.strip("\n").split("\n")
ZSPLIT = 6
MAXRISE = 4
ZBASE = (203, 166, 247)
BG = (30, 30, 46)
Z_ART = CAT[:ZSPLIT]
CAT_ART = CAT[ZSPLIT:]
def zfade(off):
    t = (off / MAXRISE) * 0.72
    c = tuple(int(ZBASE[k] * (1 - t) + BG[k] * t) for k in range(3))
    return f"{ESC}[38;2;{c[0]};{c[1]};{c[2]}m"

def run_braille(fd):
    sys.stdout.write(f"{ESC}]2;content{ESC}\\{ESC}[?25l")
    sys.stdout.flush()
    last_size = None
    frame = 0
    try:
        while True:
            drain_stdin(fd)
            size = shutil.get_terminal_size((80, 24))
            cols, rows = size.columns, size.lines
            cat_w = max(len(l) for l in CAT)
            cat_h = len(CAT)
            cx = max(0, (cols - cat_w) // 2)
            cy = max(MAXRISE + 1, (rows - cat_h) // 2)
            off = (frame // 3) % (MAXRISE + 1)
            buf = []
            if last_size != (cols, rows):
                buf.append(f"{ESC}[2J")
                last_size = (cols, rows)
            for r in range(max(1, cy - MAXRISE), cy + ZSPLIT):
                buf.append(f"{ESC}[{r};{cx}H" + " " * cat_w)
            for i, line in enumerate(CAT_ART):
                buf.append(f"{ESC}[{cy+ZSPLIT+i};{cx}H{CAT_COL}{line}{RST}")
            zcol = zfade(off)
            for i, line in enumerate(Z_ART):
                rr = cy + i - off
                if rr >= 1:
                    buf.append(f"{ESC}[{rr};{cx}H{zcol}{line}{RST}")
            hint_x = max(0, (cols - len(HINT)) // 2)
            buf.append(f"{ESC}[{cy+cat_h+2};{hint_x}H{HINT_COL}{HINT}{RST}")
            sys.stdout.write("".join(buf))
            sys.stdout.flush()
            frame += 1
            time.sleep(0.16)
    except (KeyboardInterrupt, BrokenPipeError):
        pass
    finally:
        sys.stdout.write(f"{ESC}[?25h")
        sys.stdout.flush()

# в”Җв”Җ entry в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
def main():
    fd = sys.stdin.fileno()
    old_attr = setup_tty(fd)
    try:
        cat_frames, zzz_frames = load_frames() if in_kitty_graphics() else ([], None)
        if cat_frames:
            run_kitty(fd, cat_frames, zzz_frames)
        else:
            run_braille(fd)
    finally:
        if old_attr is not None:
            try: termios.tcsetattr(fd, termios.TCSANOW, old_attr)
            except Exception: pass

if __name__ == "__main__":
    main()
