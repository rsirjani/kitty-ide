#!/usr/bin/env bash
# Single-window IDE with a custom per-pane tab system.
#   explorer | [ tab-bar / content ] | claude
# Documents open as overlays over the content pane; the tab-bar switches them.
export PATH="$HOME/.local/bin:$PATH"
mkdir -p "$HOME/.cache/ide-shots" "$HOME/.cache/ide-vd"

# A live pid that ISN'T our kitty means the pid was recycled (Linux reuses pids),
# so the old IDE is actually gone -- `kill -0` alone would wrongly keep its
# orphaned container/state. Require the pid to be a live kitty.
is_ide_kitty() { [ -r "/proc/$1/comm" ] && [ "$(cat "/proc/$1/comm" 2>/dev/null)" = kitty ]; }

reap_instance() {  # drop all per-instance state + VD container(s) for a dead pid
  local pid="$1"
  rm -rf "/tmp/ide.sock-${pid}" "/tmp/ide-${pid}-active-doc" \
    "/tmp/ide-${pid}-explorer-cwd" "/tmp/ide-${pid}-tabs-dirty" \
    "/tmp/ide-${pid}-render" "/tmp/ide-${pid}-loprofile" \
    "$HOME/.local/share/ide-carbonyl/${pid}" 2>/dev/null || true
}

# Reap only *stale* control sockets (owning kitty gone) -- never a live
# sibling's. Each IDE gets its own /tmp/ide.sock-<kitty-pid>; helper scripts
# route through KITTY_LISTEN_ON, so instances stay self-contained. (The old
# blanket `rm` here deleted running siblings' sockets, hanging their `kitty @`.)
for s in /tmp/ide.sock-*; do
  [ -S "$s" ] || continue
  pid="${s##*-}"
  case "$pid" in (*[!0-9]*) continue ;; esac      # suffix isn't a pid -> leave it
  is_ide_kitty "$pid" || reap_instance "$pid"
done
# Reap any ide-vd container whose owning kitty pid is gone -- covers all envs
# (not just linux-desktop) and pids with no leftover socket. Suffix-match the
# pid exactly so e.g. "-2790" doesn't also match "-27901".
if command -v docker >/dev/null 2>&1; then
  for c in $(docker ps -aq --filter "name=ide-vd-" 2>/dev/null); do
    n="$(docker inspect -f '{{.Name}}' "$c" 2>/dev/null)"; ipid="${n##*-}"
    case "$ipid" in (''|*[!0-9]*) continue ;; esac
    is_ide_kitty "$ipid" || docker rm -f "$c" >/dev/null 2>&1 || true
  done
fi
# Reap carbonyl profile pools owned by dead IDEs. IDE_ID is the kitty pid, so a
# new launch never reuses a dead pid's namespace -- without this the per-pid
# dirs accumulate forever (a profile tree per launch). Live instances' logins
# are kept; only dead-pid namespaces (crash/power-loss leftovers) are dropped.
cb_base="$HOME/.local/share/ide-carbonyl"
if [ -d "$cb_base" ]; then
  for d in "$cb_base"/*/; do
    [ -d "$d" ] || continue
    n="$(basename "$d")"
    case "$n" in (''|*[!0-9]*) continue ;; esac
    is_ide_kitty "$n" || rm -rf "$d" 2>/dev/null || true
  done
fi

kitty --class ide --config "$HOME/.config/kitty/ide.conf" \
  -o allow_remote_control=yes -o listen_on=unix:/tmp/ide.sock \
  -o confirm_os_window_close=0 --title "IDE" \
  --session "$HOME/.config/kitty/ide.session" &
kpid=$!
# When this IDE window exits, tear down ITS virtual desktop (instance == kitty
# pid == the socket suffix). Reap the per-window container for ANY env (not just
# linux-desktop) plus this instance's /tmp caches; a sibling IDE's VD (different
# pid) is untouched.
trap '
  if command -v docker >/dev/null 2>&1; then
    for c in $(docker ps -aq --filter "name=ide-vd-" 2>/dev/null); do
      n="$(docker inspect -f "{{.Name}}" "$c" 2>/dev/null)"
      [ "${n##*-}" = "$kpid" ] && docker rm -f "$c" >/dev/null 2>&1
    done
  fi
  rm -rf "/tmp/ide-${kpid}-render" "/tmp/ide-${kpid}-loprofile" \
    "$HOME/.local/share/ide-carbonyl/${kpid}" 2>/dev/null
  true' EXIT
wait "$kpid"
